# Скопируйте этот файл в .env и заполните своими значениями
# НИКОГДА не публикуйте .env в открытом репозитории (GitHub и т.д.)

# --- Выбор провайдера ИИ: gemini или openai ---
LLM_PROVIDER=openai

# --- Google Gemini (используется, если LLM_PROVIDER=gemini) ---
# Получить: https://aistudio.google.com -> Get API key
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- OpenAI (используется, если LLM_PROVIDER=openai) ---
# Получить: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# --- Telegram (my.telegram.org -> API development tools) ---
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
# Номер телефона аккаунта-приманки, в международном формате
TELEGRAM_PHONE=+7XXXXXXXXXX

# --- База данных ---
DATABASE_URL=sqlite:///./qalqan.db

# --- Порог автопилота (0-10). Если риск сообщения ниже порога,
# ответ можно отправлять автоматически без подтверждения оператора.
# Рекомендуется оставить 0 (всегда подтверждать вручную), пока не протестируете систему.
AUTOPILOT_RISK_THRESHOLD=0

# --- Контакт админа Qalqan (Telegram username БЕЗ @) ---
# Именно сюда уходит итоговый отчёт по кнопке "Сформировать и отправить отчёт".
# Дальше админ вручную передаёт отчёт в банк/МВД.
ADMIN_TELEGRAM_USERNAME=your_admin_username_here

# --- Порог "высокого риска" (0-10), при котором в дашборде появляется
# заметный баннер-предупреждение оператору
HIGH_RISK_THRESHOLD=7
